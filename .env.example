# ros_bridge 설정 템플릿. 복사해서 .env로 쓰고 값 채우기:  cp .env.example .env
# .env는 gitignore(비밀값·실 IP는 .env에만).

# Flask 서버가 바인딩할 주소
TANK_BRIDGE_HOST=0.0.0.0

# 실행 모드: monitor(수동 조작) | auto(ROS 자율주행). 그 외 값은 안전상 monitor로 강제.
TANK_MODE=monitor

# 명령 timeout / fallback
TANK_COMMAND_TTL_SEC=5.0
TANK_AUTO_FALLBACK=stop

# Ubuntu 서버(브릿지) 포트
TANK_BRIDGE_PORT=5000

# 접속 허용할 Windows 시뮬레이터 PC IP -> 마지막에 본인 시뮬 PC 실제 IP 추가
TANK_ALLOWED_CLIENTS=127.0.0.1,::1,<시뮬PC_IP>

# YOLO 모델 경로(.pt 권장: 의존성 충돌·로딩 지연 방지). 절대경로로 본인 환경에 맞게.
TANK_YOLO_MODEL_PATH=/home/<user>/tank_project/src/vision/models/best_final.pt

# 로그 저장 옵션(LiDAR 로그 폭탄 방지). 정찰 산출물은 recon_reports/로 별도 기록.
TANK_SAVE_FULL_INFO=false
TANK_SAVE_JSONL=false
