# ============================================================
#  Tank Challenge — ros_bridge 설정 (.env)
#  사용법:  cp .env.example .env   후 아래 "여기만 수정"을 채운다.
#  - .env는 gitignore(실 IP·절대경로는 .env에만). 빈 값/없는 키는 config.py 기본값 사용.
#  - 이 .env는 워크스페이스 루트에서 ros2 run 시 자동 로드된다(명령에 env 안 붙여도 됨).
# ============================================================

# ============================================================
#  ▶ 여기만 수정 (우분투 브릿지 측)
# ============================================================
# 이 .env는 "우분투(브릿지) PC" 설정이다. 여기서 IP는 "접속 허용할 윈도우 PC IP" 하나뿐.
# 서브넷 와일드카드 권장(대역 안에서 IP가 바뀌어도 그대로):
TANK_ALLOWED_CLIENTS=127.0.0.1,::1,192.168.0.*
#    정확 IP만:  127.0.0.1,::1,192.168.0.30   |  CIDR:  192.168.0.0/24   |  loopback은 항상 허용.
#  ※ "우분투 IP"는 여기가 아니라 윈도우의 tank_proxy.py UBUNTU_SERVER(=http://<우분투IP>:5000)에 적는다.
#     (시뮬에는 포트만 설정 → 프록시가 우분투로 중계. 아래 "(윈도우 전용)" 섹션 참고. 우분투 IP: hostname -I)

# ============================================================
#  핵심
# ============================================================
# 운용 모드: monitor(수동/관측) | auto(ROS 자율주행). 그 외 값은 안전상 monitor로 강제.
#   (run_bridge.sh --mode auto 로도 지정 가능)
TANK_MODE=monitor
# 브릿지 포트 — 프록시 UBUNTU_SERVER·시뮬 포트와 전부 일치(5000). 팀 표준.
TANK_BRIDGE_PORT=5000
# 바인딩 주소(외부(윈도우)에서 접속 받으려면 0.0.0.0 유지).
TANK_BRIDGE_HOST=0.0.0.0
# YOLO 모델 경로(절대경로). 기본은 best_final.engine(TensorRT, GPU 필요).
#   GPU 없는 PC는 best_final.pt 로 바꿀 것(엔진은 GPU 전용).
TANK_YOLO_MODEL_PATH=/home/<user>/tank_project/src/vision/models/best_final.engine

# ============================================================
#  정찰 / RL — 에피소드 제어 (루트 사이 시뮬 자동 리셋)
# ============================================================
# true면 /tank/episode/control 로 reset/pause/start를 시뮬에 하달(정찰 자동리셋·RL). 기본 off.
#   (run_recon.sh, run_bridge.sh --reset 가 자동으로 켠다)
TANK_EPISODE_CONTROL=false

# ============================================================
#  선택 — 웹뷰 / YOLO
# ============================================================
# 브릿지 내 /view, /video_feed 라이브뷰 제공.
TANK_LIVE_VIEW=true
# 웹 MFD 경량화(제어 루프와 같은 Flask/GIL 공유 → 웹 켜면 느려지는 것 완화).
#   REFRESH_SEC : 무거운 대시보드 payload를 백그라운드에서 만드는 주기(초). HTTP 핸들러는 캐시만 반환.
#   POLL_MS     : 브라우저 폴링 간격(ms). 대시보드는 사람이 보는 화면이라 1초면 충분(기존 300ms).
#   STATIC_MAP_CACHE_TTL_SEC : 정적맵(거의 안 바뀜) 파일 캐시 TTL(초).
TANK_DASHBOARD_REFRESH_SEC=0.8
TANK_DASHBOARD_POLL_MS=1000
TANK_STATIC_MAP_CACHE_TTL_SEC=5.0
# YOLO 추론 모드:  false = 동기(sync, 기본·항상 동작)  /  true = 비동기(async).
#   ★ async(true)는 GPU+engine 빠른 머신 전용. 느린 머신(GPU 없음 등)은 검출이 stale로 drop돼
#     발견객체(discovered) 기록이 안 됨. 정찰 발견 기록엔 sync(false) 권장.
TANK_YOLO_ASYNC=false
TANK_YOLO_ASYNC_MAX_RESULT_AGE_MS=300

# ============================================================
#  안전 / 로깅 (보통 그대로)
# ============================================================
# 최신 ROS 명령이 없을 때 정책: stop | neutral.
TANK_AUTO_FALLBACK=stop
# 명령 유효시간(초). 초과 시 fallback 명령으로 대체.
TANK_COMMAND_TTL_SEC=5.0
# 디버그 JSONL 로그(tank_logs/) 저장. 기본 off. 정찰 산출물은 recon_reports/로 별도 기록.
TANK_SAVE_JSONL=false
# /info 원본 전체 저장 여부(LiDAR 로그 폭탄 방지).
TANK_SAVE_FULL_INFO=false

# ============================================================
#  (윈도우 전용) tank_proxy.py — 시뮬은 포트만 설정 가능해서 윈도우에서 프록시로 중계
# ============================================================
# 시뮬 → 127.0.0.1:PROXY_PORT → tank_proxy.py → UBUNTU_SERVER(우분투 브릿지). 우분투 IP는 `hostname -I`.
# (이 두 값은 윈도우에서 tank_proxy.py 실행 시에만 쓰임. 우분투 브릿지는 무시.)
UBUNTU_SERVER=http://<우분투IP>:5000
PROXY_PORT=5000
